diff --git a/src/inc/msquic.h b/src/inc/msquic.h
index a60a588..385edfa 100644
--- a/src/inc/msquic.h
+++ b/src/inc/msquic.h
@@ -1226,6 +1226,7 @@ typedef enum QUIC_LISTENER_EVENT_TYPE {
     QUIC_LISTENER_EVENT_NEW_CONNECTION      = 0,
     QUIC_LISTENER_EVENT_STOP_COMPLETE       = 1,
     QUIC_LISTENER_EVENT_DOS_MODE_CHANGED    = 2,
+    QUIC_LISTENER_EVENT_UNCONNECTED_QUERY   = 3,    // Out-of-RFC connectionless UDP query (parties patch)
 } QUIC_LISTENER_EVENT_TYPE;
 
 typedef struct QUIC_LISTENER_EVENT {
@@ -1243,6 +1244,22 @@ typedef struct QUIC_LISTENER_EVENT {
             BOOLEAN DosModeEnabled : 1;
             BOOLEAN RESERVED       : 7;
         } DOS_MODE_CHANGED;
+        //
+        // Out-of-RFC connectionless server query (parties patch). An unencrypted
+        // UDP datagram matching the app's magic arrived on the listener's port.
+        // The app inspects Payload, writes up to ReplyBufferLength bytes into
+        // ReplyBuffer, sets ReplyBufferLength to the number actually written, and
+        // returns QUIC_STATUS_SUCCESS to send the reply. Returning a failure
+        // status or a length of 0 sends nothing. The reply capacity is capped to
+        // the request length (anti-amplification), so pad the request as needed.
+        //
+        struct {
+            const QUIC_ADDR* RemoteAddress;     // IN:  sender of the query
+            const uint8_t*   Payload;           // IN:  received datagram bytes
+            uint16_t         PayloadLength;     // IN:  length of Payload
+            uint8_t*         ReplyBuffer;       // OUT: app writes the reply here
+            uint16_t         ReplyBufferLength; // IN: capacity; OUT: bytes written
+        } UNCONNECTED_QUERY;
     };
 } QUIC_LISTENER_EVENT;
 
