     QUIC_OPER_TYPE_VERSION_NEGOTIATION, // A version negotiation needs to be sent.
     QUIC_OPER_TYPE_STATELESS_RESET,     // A stateless reset needs to be sent.
     QUIC_OPER_TYPE_RETRY,               // A retry needs to be sent.
